{
  "id": "audiences",
  "name": "观众",
  "domain": "https://audiences.me",
  "encoding": "UTF-8",
  "public": false,
  "html": {
    "search": {
      "paths": [
        {
          "path": "torrents.php",
          "method": "get"
        }
      ],
      "params": {
        "search": "{keyword}"
      },
      "batch": {
        "delimiter": " ",
        "space_replace": "_"
      }
    },
    "category": {
      "movie": [
        {
          "id": 401,
          "cat": "Movies",
          "desc": "电影/Movies"
        }
      ],
      "tv": [
        {
          "id": 402,
          "cat": "TV",
          "desc": "剧集/TV-Series"
        },
        {
          "id": 403,
          "cat": "TV",
          "desc": "综艺/TV-Show"
        },
        {
          "id": 406,
          "cat": "TV/Documentary",
          "desc": "纪录片/Documentary"
        }
      ]
    },
    "torrents": {
      "list": {
        "selector": "table.torrents > tr:has(\"table.torrentname\")"
      },
      "fields": {
        "id": {
          "selector": "a[href*=\"details.php?id=\"]",
          "attribute": "href",
          "filters": [
            {
              "name": "re_search",
              "args": [
                "\\d+",
                0
              ]
            }
          ]
        },
        "title_default": {
          "selector": "a[href*=\"details.php?id=\"]"
        },
        "title_optional": {
          "optional": true,
          "selector": "a[title][href*=\"details.php?id=\"]",
          "attribute": "title"
        },
        "title": {
          "text": "{% if fields['title_optional'] %}{{ fields['title_optional'] }}{% else %}{{ fields['title_default'] }}{% endif %}"
        },
        "category": {
          "selector": "a[href*=\"?cat=\"]",
          "attribute": "href",
          "filters": [
            {
              "name": "replace",
              "args": [
                "?",
                ""
              ]
            },
            {
              "name": "querystring",
              "args": "cat"
            }
          ]
        },
        "details": {
          "selector": "a[href*=\"details.php?id=\"]",
          "attribute": "href"
        },
        "download": {
          "selector": "a[href*=\"download.php?id=\"]",
          "attribute": "href"
        },
        "imdbid": {
          "selector": "div.imdb_100 > a",
          "attribute": "href",
          "filters": [
            {
              "name": "re_search",
              "args": [
                "tt\\d+",
                0
              ]
            }
          ]
        },
        "date_elapsed": {
          "selector": "td:nth-child(4) > span",
          "optional": true
        },
        "date_added": {
          "selector": "td:nth-child(4) > span",
          "attribute": "title",
          "optional": true
        },
        "date": {
          "text": "{% if fields['date_elapsed'] or fields['date_added'] %}{{ fields['date_elapsed'] if fields['date_elapsed'] else fields['date_added'] }}{% else %}now{% endif %}",
          "filters": [
            {
              "name": "dateparse",
              "args": "%Y-%m-%d %H:%M:%S"
            }
          ]
        },
        "size": {
          "selector": "td:nth-child(5)"
        },
        "seeders": {
          "selector": "td:nth-child(6)"
        },
        "leechers": {
          "selector": "td:nth-child(7)"
        },
        "grabs": {
          "selector": "td:nth-child(8)"
        },
        "downloadvolumefactor": {
          "case": {
            "img.pro_free": 0,
            "img.pro_free2up": 0,
            "img.pro_50pctdown": 0.5,
            "img.pro_50pctdown2up": 0.5,
            "img.pro_30pctdown": 0.3,
            "*": 1
          }
        },
        "uploadvolumefactor": {
          "case": {
            "img.pro_50pctdown2up": 2,
            "img.pro_free2up": 2,
            "img.pro_2up": 2,
            "*": 1
          }
        },
        "free_deadline": {
          "default_value": "{% if fields['downloadvolumefactor']==0 %}{{max_time}}{% endif%}",
          "default_value_format": "%Y-%m-%d %H:%M:%S.%f",
          "selector": "img.pro_free,img.pro_free2up",
          "attribute": "onmouseover",
          "filters": [
            {
              "name": "re_search",
              "args": [
                "\\d+-\\d+-\\d+ \\d+:\\d+:\\d+",
                0
              ]
            },
            {
              "name": "dateparse",
              "args": "%Y-%m-%d %H:%M:%S"
            }
          ]
        },
        "description": {
          "selector": "td.embedded > span[style]"
        },
        "labels": {
          "selector": "td.embedded > span.tags"
        }
      }
    },
    "conf": {
      "FREE": [
        "//h1[@id='top']/b/font[@class='free']"
      ],
      "2XFREE": [
        "//h1[@id='top']/b/font[@class='twoupfree']"
      ],
      "HR": [
        "//h1[@id='top']/img[@class='hitandrun']"
      ],
      "PEER_COUNT": [
        "//div[@id='peercount']/b[1]"
      ]
    }
  },
  "user_info": {
    "type": "html",
    "fields": {
      "userid": {
        "selector": "a[href*=\"userdetails\"]",
        "attribute": "href",
        "pattern": "id=(\\d+)",
        "extract": "int"
      },
      "username": {
        "selector": "a[href*=\"userdetails\"] > b",
        "extract": "text"
      },
      "upload": {
        "selector": "span[data-uploader-stats]",
        "attribute": "data-uploader-stats",
        "pattern": "\"label\":\"上传量：\",\"value\":\"([^\"]+)\"",
        "extract": "filesize"
      },
      "download": {
        "selector": "span[data-uploader-stats]",
        "attribute": "data-uploader-stats",
        "pattern": "\"label\":\"下载量：\",\"value\":\"([^\"]+)\"",
        "extract": "filesize"
      },
      "ratio": {
        "selector": ".site-userbar__compact-metric--ratio span",
        "extract": "float"
      },
      "bonus": {
        "selector": "span[data-uploader-stats]",
        "attribute": "data-uploader-stats",
        "pattern": "\"label\":\"爆米花：\",\"value\":\"([\\d,.]+)\"",
        "extract": "float"
      },
      "leeching": {
        "selector": "span[data-uploader-stats]",
        "attribute": "data-uploader-stats",
        "pattern": "\"label\":\"活跃\",\"value\":\"↑ \\d+ / ↓ (\\d+)\"",
        "extract": "int"
      },
      "user_level": {
        "selector": "span[data-uploader-badge]",
        "attribute": "data-uploader-badge",
        "pattern": "\\((.*)\\)",
        "extract": "text"
      },
      "join_at": {
        "selector": "",
        "extract": "regex",
        "pattern": "加入日期[\\s\\S]*?(\\d{4}-\\d{2}-\\d{2})"
      }
    },
    "seeding": {
      "total_regex": "<b>(\\d+)</b>条记录 Total: ([\\d.]+\\s*[KMGT]B)",
      "page": "getusertorrentlistajax.php?userid={userid}&type=seeding"
    }
  }
}