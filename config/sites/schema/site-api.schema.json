{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nexus-media/schema/site-api.schema.json",
  "title": "API 站点定义 Schema",
  "description": "通过 HTTP API 进行搜索的站点定义格式",
  "type": "object",
  "required": ["id", "name", "domain", "api"],
  "properties": {
    "id": {"type": "string", "description": "站点唯一标识符，如 mteam、yemapt"},
    "name": {"type": "string", "description": "站点显示名称"},
    "domain": {"type": "string", "description": "主域名，用于 URL 匹配"},
    "domain_aliases": {"type": "array", "items": {"type": "string"}, "description": "域名别名列表"},
    "encoding": {"type": "string", "default": "UTF-8"},
    "public": {"type": "boolean", "default": false, "description": "是否公开站点"},
    "favicon": {"type": "string", "description": "站点图标 URL，为空则自动抓取"},
    "language": {"type": "string", "description": "站点语言过滤"},
    "tid_pattern": {"type": "string", "default": "\\d+", "description": "提取种子 ID 的正则"},
    "detail_page_url": {"type": "string", "description": "种子详情页 URL 模板"},
    "api": {"$ref": "#/definitions/api_config"},
    "download": {"$ref": "#/definitions/download_config"},
    "torrent_attr": {"$ref": "#/definitions/torrent_attr_config"},
    "subtitle": {"$ref": "#/definitions/subtitle_config"},
    "user_info": {"$ref": "#/definitions/user_info_config"}
  },

  "definitions": {
    "api_config": {
      "type": "object",
      "required": ["base_url", "auth", "endpoints"],
      "properties": {
        "base_url": {"type": "string", "description": "API 基础地址"},
        "auth": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": {"enum": ["api_key", "bearer", "cookie", "csrf", "passkey", "token"]},
            "header_name": {"type": "string", "description": "API 密钥的 header 名称"},
            "token_source": {"type": "string", "description": "cookie 中 token 的键名"},
            "csrf_url": {"type": "string", "description": "获取 CSRF token 的 URL"},
            "csrf_selector": {"type": "string", "description": "从 HTML 提取 CSRF 的选择器"}
          }
        },
        "endpoints": {
          "type": "object",
          "required": ["search"],
          "properties": {
            "search": {"$ref": "#/definitions/endpoint"},
            "detail": {"$ref": "#/definitions/endpoint"},
            "test_connection": {"$ref": "#/definitions/endpoint"},
            "user_info": {"$ref": "#/definitions/endpoint"}
          }
        }
      }
    },
    "endpoint": {
      "type": "object",
      "required": ["method", "path"],
      "properties": {
        "method": {"enum": ["GET", "POST"]},
        "path": {"type": "string", "description": "请求路径，支持 {keyword} {page_1} {tid} 占位"},
        "params": {"type": "object", "description": "查询参数"},
        "body": {"type": "object", "description": "请求体"},
        "response_key": {"type": "string", "description": "响应中提取数据的 JSON 路径"},
        "mode_mapping": {
          "type": "object",
          "description": "媒体类型到请求参数的映射（MOVIE/TV/ANIME → body/params 覆盖）"
        },
        "response": {
          "type": "object",
          "properties": {
            "total_key": {"type": "string", "description": "总数的 JSON 路径"},
            "items_key": {"type": "string", "description": "列表的 JSON 路径"},
            "item_mapping": {
              "type": "object",
              "properties": {
                "id": {"$ref": "#/definitions/field_mapping"},
                "title": {"$ref": "#/definitions/field_mapping"},
                "description": {"$ref": "#/definitions/field_mapping"},
                "details": {"$ref": "#/definitions/field_mapping"},
                "download": {"$ref": "#/definitions/field_mapping"},
                "enclosure": {"$ref": "#/definitions/field_mapping"},
                "page_url": {"$ref": "#/definitions/field_mapping"},
                "poster": {"$ref": "#/definitions/field_mapping"},
                "size": {"$ref": "#/definitions/field_mapping"},
                "seeders": {"$ref": "#/definitions/field_mapping"},
                "leechers": {"$ref": "#/definitions/field_mapping"},
                "grabs": {"$ref": "#/definitions/field_mapping"},
                "date_elapsed": {"$ref": "#/definitions/field_mapping"},
                "date_added": {"$ref": "#/definitions/field_mapping"},
                "pubdate": {"$ref": "#/definitions/field_mapping"},
                "imdbid": {"$ref": "#/definitions/field_mapping"},
                "uploadvolumefactor": {"$ref": "#/definitions/field_mapping"},
                "downloadvolumefactor": {"$ref": "#/definitions/field_mapping"},
                "free_deadline": {"$ref": "#/definitions/field_mapping"},
                "labels": {"$ref": "#/definitions/field_mapping"},
                "tags": {"$ref": "#/definitions/field_mapping"},
                "category": {"$ref": "#/definitions/field_mapping"},
                "category_icon": {"$ref": "#/definitions/field_mapping"}
              }
            }
          }
        }
      }
    },
    "field_mapping": {
      "type": "object",
      "properties": {
        "source": {"type": "string", "description": "JSON 路径，点号分隔"},
        "type": {"enum": ["mapping", "api", "constant", "template", "html", "int", "float"]},
        "method": {"enum": ["GET", "POST"]},
        "path": {"type": "string"},
        "body": {"type": "object"},
        "response_key": {"type": "string"},
        "value": {"description": "constant 类型的固定值"},
        "map": {"type": "object", "description": "值映射表"},
        "transform": {"type": "string", "description": "值转换: map_value, utc_to_local"},
        "filters": {"type": "array", "items": {"type": "object"}},
        "selector": {"type": "string", "description": "HTML 类型时的 CSS 选择器"},
        "attribute": {"type": "string", "description": "HTML 类型时提取的属性"},
        "fields": {"type": "object", "description": "template 类型引用的字段"},
        "domains": {"type": "array", "items": {"type": "string"}}
      }
    },
    "download_config": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {"enum": ["api", "api_chained", "template", "html"]},
        "method": {"enum": ["GET", "POST"]},
        "path": {"type": "string", "description": "下载链接路径模板"},
        "body": {"type": "object"},
        "response_key": {"type": "string", "description": "响应中提取下载链接的 JSON 路径"},
        "params": {"type": "object"},
        "download_url": {"type": "string", "description": "下载域名/前缀覆盖"},
        "selectors": {"type": "object", "description": "HTML 类型时的下载链接选择器"}
      }
    },
    "torrent_attr_config": {
      "type": "object",
      "description": "种子属性增强配置",
      "properties": {
        "fields": {"type": "object"},
        "url": {"type": "string"},
        "method": {"enum": ["GET", "POST"]},
        "body": {"type": "object"}
      }
    },
    "subtitle_config": {
      "type": "object",
      "properties": {
        "type": {"enum": ["api", "html"]},
        "list": {"$ref": "#/definitions/endpoint"},
        "genlink": {"$ref": "#/definitions/endpoint"},
        "download": {"$ref": "#/definitions/endpoint"}
      }
    },
    "user_info_config": {
      "type": "object",
      "description": "用户信息解析配置",
      "properties": {
        "type": {"type": "string", "enum": ["api", "html"]},
        "profile": {"$ref": "#/definitions/user_info_endpoint"},
        "seeding": {"$ref": "#/definitions/user_info_seeding"},
        "fields": {"type": "object"},
        "bonus_labels": {"type": "array", "items": {"type": "string"}}
      }
    },
    "user_info_endpoint": {
      "type": "object",
      "properties": {
        "method": {"enum": ["GET", "POST"]},
        "path": {"type": "string"},
        "body": {"type": "object"},
        "response": {
          "type": "object",
          "properties": {
            "field_mapping": {
              "type": "object",
              "properties": {
                "user_id": {"$ref": "#/definitions/field_mapping"},
                "username": {"$ref": "#/definitions/field_mapping"},
                "upload": {"$ref": "#/definitions/field_mapping"},
                "download": {"$ref": "#/definitions/field_mapping"},
                "ratio": {"$ref": "#/definitions/field_mapping"},
                "bonus": {"$ref": "#/definitions/field_mapping"},
                "user_level": {"$ref": "#/definitions/field_mapping"},
                "join_at": {"$ref": "#/definitions/field_mapping"},
                "leeching": {"$ref": "#/definitions/field_mapping"}
              }
            }
          }
        }
      }
    },
    "user_info_seeding": {
      "type": "object",
      "properties": {
        "type": {"type": "string", "enum": ["api", "html"]},
        "method": {"enum": ["GET", "POST"]},
        "path": {"type": "string"},
        "body": {"type": "object"},
        "page": {"type": "string"},
        "list_selector": {"type": "string"},
        "size_selector": {"type": "string"},
        "seeders_selector": {"type": "string"},
        "total_regex": {"type": "string"},
        "response": {
          "type": "object",
          "properties": {
            "response_type": {"enum": ["single", "paginated"]},
            "items_key": {"type": "string"},
            "seeders_field": {"type": "string"},
            "size_field": {"type": "string"}
          }
        },
        "pagination": {
          "type": "object",
          "properties": {
            "type": {"enum": ["page_param", "offset", "none"]},
            "total_pages_key": {"type": "string"},
            "next_key": {"type": "string"},
            "page_param": {"type": "string"},
            "start_value": {"type": "integer"}
          }
        }
      }
    }
  }
}
