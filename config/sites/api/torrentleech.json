{
  "id": "torrentleech",
  "name": "TorrentLeech",
  "domain": "torrentleech.org",
  "domain_aliases": [],
  "tid_pattern": "\\d+",
  "detail_page_url": "/torrent/{fid}",
  "encoding": "UTF-8",
  "public": false,
  "api": {
    "base_url": "https://torrentleech.org",
    "auth": {
      "type": "cookie"
    },
    "endpoints": {
      "search": {
        "method": "GET",
        "path": "/torrents/browse/list/query/{keyword}",
        "response": {
          "items_key": "torrentList",
          "item_mapping": {
            "title": {"source": "name"},
            "enclosure": {
              "type": "template",
              "value": "{domain}/download/{fid}/{filename}",
              "fields": {"domain": "domain", "fid": "fid", "filename": "filename"}
            },
            "pubdate": {"source": "addedTimestamp", "transform": "timestamp_to_date"},
            "size": {"source": "size"},
            "seeders": {"source": "seeders"},
            "leechers": {"source": "leechers"},
            "grabs": {"source": "completed"},
            "downloadvolumefactor": {"source": "download_multiplier"},
            "uploadvolumefactor": {"type": "constant", "value": 1.0},
            "imdbid": {"source": "imdbID"},
            "page_url": {
              "type": "template",
              "value": "/torrent/{fid}",
              "fields": {"fid": "fid"}
            }
          }
        }
      },
      "test_connection": {
        "method": "GET",
        "path": "/torrents/browse/list/page/1"
      },
      "user_info": {
        "method": "GET",
        "path": "/api/user/profile"
      }
    }
  }
}
