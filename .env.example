# Nexus Media 环境变量配置
# 复制为 .env 后修改，优先级：环境变量 > .env > config.yaml
# 嵌套 key 用 __ 分隔，如 APP__WEB_PORT -> AppSettings.app.web_port

# ==================== 核心 ====================
TZ=Asia/Shanghai
# NEXUS_PORT=3000

# ==================== 数据库 ====================
# DATABASE__TYPE=mysql
# DATABASE__HOST=localhost
# DATABASE__PORT=3306
# DATABASE__USERNAME=nexus_media
# DATABASE__PASSWORD=nexus_media_password
# DATABASE__DATABASE=nexus_media

# ==================== 应用 ====================
# APP__WEB_HOST=::
# APP__WEB_PORT=3000
# APP__LOGIN_USER=admin
# APP__LOGIN_PASSWORD=password
# APP__DEBUG=true
# APP__DOMAIN=example.com
# APP__RMT_TMDBKEY=
# APP__WALLPAPER=bing

# ==================== 媒体 ====================
# MEDIA__TMDB_LANGUAGE=zh
# MEDIA__MEDIASYNC_INTERVAL=8
# MEDIA__DEFAULT_RMT_MODE=link

# ==================== 订阅监控 ====================
# SUBSCRIBE__QUEUE_INTERVAL=300
# SUBSCRIBE__RSS_INTERVAL=1800
# SUBSCRIBE__SEARCH_INTERVAL=6

# ==================== PT 站点 ====================
# PT__SEARCH_AUTO=false
# PT__DOWNLOAD_ORDER=seeder

# ==================== 安全 ====================
# SECURITY__JWT_SECRET=

# ==================== 实验室 ====================
# LABORATORY__CHROME_SERVER_HOST=http://localhost:9850
# LABORATORY__OCR_SERVER_HOST=http://localhost:9300

# ==================== Redis ====================
# REDIS__HOST=127.0.0.1
# REDIS__PORT=6379
# REDIS__PASSWORD=
# REDIS__DB=0

# ==================== 日志 ====================
# LOG__TYPE=file
# LOG__LEVEL=debug
# LOG__PATH=./logs
# LOG__FORMAT=json

# ==================== Agent ====================
# AGENT__ENABLED=false
# AGENT__DEFAULT_PROVIDER=deepseek
# AGENT__PROVIDERS__DEEPSEEK__API_KEY=
# AGENT__PROVIDERS__DEEPSEEK__API_URL=https://api.deepseek.com
# AGENT__PROVIDERS__DEEPSEEK__MODEL=deepseek-chat
