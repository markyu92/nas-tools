# Nexus Media 环境变量配置样例
# 复制此文件为 .env 并填写实际值
# pydantic-settings 会自动读取 .env 文件，优先级高于 config.yaml

# ============================================
# 基础配置
# ============================================

# config.yaml 配置文件路径（必须设置）
NEXUS_MEDIA_CONFIG=/home/linyuan/python/config/config.yaml

# 时区
TZ=Asia/Shanghai

# ============================================
# 数据库配置（可选，配置后将覆盖 config.yaml）
# ============================================

# 数据库类型：sqlite / postgresql
DB_TYPE=sqlite

# PostgreSQL 配置（DB_TYPE=postgresql 时必填）
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=nexus_media
DB_PASSWORD=your_password
DB_NAME=nexus_media

# ============================================
# Redis 配置（可选）
# ============================================

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ============================================
# 日志配置（可选）
# ============================================

# 日志类型：console / file / server
LOG_TYPE=console

# 日志中心地址（LOG_TYPE=server 时必填）
LOG_SERVER=

# 日志文件路径（LOG_TYPE=file 时必填）
LOG_PATH=/home/linyuan/python/config/logs

# ============================================
# 网络配置（可选）
# ============================================

# HTTP 代理地址
PROXIES=http://127.0.0.1:7890

# 自定义 User-Agent
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# TMDB API 域名（可选，覆盖 config.yaml）
TMDB_API_DOMAIN=api.themoviedb.org

# ============================================
# 安全配置（可选）
# ============================================

# API Key
API_KEY=
