# Nexus Media 环境变量配置
# 复制为 .env 后修改，优先级：环境变量 > .env > config.yaml
# NEXUS_MEDIA_CONFIG 必须在系统环境变量中设置，不能写在 .env 中

# ==================== 核心 ====================
TZ=Asia/Shanghai
# NEXUS_PORT=3000
# SERVER_INSTANCE=node-1

# ==================== 数据库（覆盖 config.yaml） ====================
# DB_TYPE=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USERNAME=nexus_media
# DB_PASSWORD=nexus_media_password
# DB_NAME=nexus_media

# ==================== 应用配置（嵌套 key 用 __ 分隔） ====================
# APP__WEB_HOST=::
# APP__WEB_PORT=3001
# APP__LOGIN_USER=admin
# APP__LOGIN_PASSWORD=password
# APP__DEBUG=true
# APP__DOMAIN=example.com

# ==================== 日志 ====================
# LOG_FORMAT=json
# NEXUS_MEDIA_LOG=/var/log/nexus-media

# ==================== Gunicorn（生产模式） ====================
# GUNICORN_WORKERS=4
# GUNICORN_LOG_LEVEL=info

# ==================== 站点配置 ====================
# NEXUS_SITES_DIR=/custom/sites/dir
