# Nexus Media Web 前端 Dockerfile
# 独立构建前端静态资源，由 Nginx 服务

FROM node:20-alpine AS builder

WORKDIR /app

# 安装 pnpm
RUN npm install -g pnpm@10.28.2

# 复制依赖配置
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY tsconfig*.json turbo.json *.yaml ./
COPY scripts ./scripts
COPY internal ./internal
COPY packages ./packages
COPY apps/nas-tools/package.json ./apps/nas-tools/

# 安装依赖
RUN pnpm install --frozen-lockfile

# 复制源码并构建
COPY apps/nas-tools ./apps/nas-tools
RUN pnpm --filter @nas-tools/frontend run build

# 运行时：Nginx 服务静态资源
FROM nginx:alpine

# 复制构建产物
COPY --from=builder /app/apps/nas-tools/dist /usr/share/nginx/html

# 复制 Nginx 配置
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
