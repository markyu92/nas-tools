{
  "manifest_version": "1.0",
  "id": "libraryscraper",
  "name": "媒体库刮削",
  "version": "1.0",
  "author": "linyuan0213",
  "author_url": "https://github.com/linyuan0213",
  "description": "定时对媒体库进行刮削，补齐缺失元数据和图片。",
  "category": "media",
  "tags": ["刮削", "元数据"],
  "icon": "lucide:file-search",
  "color": "#f97316",
  "min_app_version": "3.0.0",
  "backend": {
    "entry": "backend.plugin:LibraryScraperPlugin",
    "api_prefix": "/api/plugin/libraryscraper",
    "permissions": [],
    "hooks": [
      "plugin.config_changed",
      "media.scraped"
    ],
    "supports_run": true
  },
  "frontend": {
    "routes": [],
    "settings": {
      "component": "SettingsPage",
      "fields": [
        {
          "key": "cron",
          "type": "cron",
          "label": "刮削周期",
          "default": "0 0 * * *",
          "placeholder": "0 0 * * *",
          "help": "支持5位cron表达式；刮削时间根据媒体库文件数量及网络状况而定"
        },
        {
          "key": "mode",
          "type": "select",
          "label": "刮削模式",
          "default": "no_force",
          "options": [
            {"label": "仅刮削缺失的元数据和图片", "value": "no_force"},
            {"label": "覆盖所有元数据", "value": "force_nfo"},
            {"label": "覆盖所有元数据和图片", "value": "force_all"}
          ],
          "help": "选择刮削模式"
        },
        {
          "key": "scraper_path",
          "type": "textarea",
          "label": "刮削路径",
          "default": "",
          "placeholder": "每行一个路径",
          "help": "需要刮削的媒体库路径"
        },
        {
          "key": "exclude_path",
          "type": "input",
          "label": "排除路径",
          "default": "",
          "placeholder": "多个路径用,分割",
          "help": "需要排除的媒体库路径"
        },
        {
          "key": "onlyonce",
          "type": "switch",
          "label": "立即运行一次",
          "default": false,
          "help": "打开后立即运行一次"
        }
      ]
    },
    "slots": []
  }
}
