{
  "manifest_version": "1.0",
  "id": "iyuuautoseed",
  "name": "IYUU自动辅种",
  "version": "1.1",
  "author": "linyuan0213",
  "author_url": "https://github.com/linyuan0213",
  "description": "基于IYUU官方Api实现自动辅种。",
  "category": "download",
  "tags": ["辅种", "IYUU"],
  "icon": "lucide:copy",
  "color": "#eab308",
  "min_app_version": "3.0.0",
  "backend": {
    "entry": "backend.plugin:IYUUAutoSeedPlugin",
    "api_prefix": "/api/plugin/iyuuautoseed",
    "permissions": [],
    "hooks": [
      "plugin.config_changed"
    ],
    "supports_run": true
  },
  "frontend": {
    "routes": [],
    "settings": {
      "component": "SettingsPage",
      "fields": [
        {
          "key": "enable",
          "type": "switch",
          "label": "开启自动辅种",
          "default": false,
          "help": "开启后自动监控下载器，对下载完成的任务自动辅种"
        },
        {
          "key": "token",
          "type": "input",
          "label": "IYUU Token",
          "default": "",
          "placeholder": "IYUUxxx",
          "help": "登录IYUU使用的Token"
        },
        {
          "key": "cron",
          "type": "cron",
          "label": "执行周期",
          "default": "0 0 * * *",
          "placeholder": "0 0 * * *",
          "help": "辅种任务执行的时间周期"
        },
        {
          "key": "nolabels",
          "type": "input",
          "label": "不辅种标签",
          "default": "",
          "placeholder": "使用,分隔多个标签",
          "help": "下载器中的种子有以下标签时不进行辅种"
        },
        {
          "key": "notify",
          "type": "switch",
          "label": "运行时通知",
          "default": false,
          "help": "运行辅助任务后发送通知"
        },
        {
          "key": "onlyonce",
          "type": "switch",
          "label": "立即运行一次",
          "default": false,
          "help": "打开后立即运行一次"
        },
        {
          "key": "clearcache",
          "type": "switch",
          "label": "下一次运行时清除缓存",
          "default": false,
          "help": "清除辅种缓存，出错的种子会重新尝试辅种"
        }
      ]
    },
    "slots": []
  }
}
