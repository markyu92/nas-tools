{
  "manifest_version": "1.0",
  "id": "weworkipchange",
  "name": "企业微信可信任IP更新",
  "version": "1.1",
  "author": "linyuan0213",
  "author_url": "https://github.com/linyuan0213",
  "description": "定时获取动态IP更新到企业微信可信任IP列表",
  "category": "tool",
  "tags": ["企业微信", "IP", "动态"],
  "icon": "lucide:building-2",
  "color": "#BFBFBF",
  "min_app_version": "3.0.0",
  "backend": {
    "entry": "backend.plugin:WeworkIPChangePlugin",
    "api_prefix": "/api/plugin/weworkipchange",
    "permissions": [],
    "hooks": [
      "plugin.config_changed"
    ],
    "supports_run": true
  },
  "frontend": {
    "routes": [],
    "settings": {
      "component": "SettingsPage",
      "fields": [
        {
          "key": "enabled",
          "type": "switch",
          "label": "启用插件",
          "default": false,
          "help": "开启后会根据周期定时获取IP更新到可信任IP列表"
        },
        {
          "key": "cron",
          "type": "cron",
          "label": "同步周期",
          "default": "",
          "placeholder": "0 0 * * *",
          "help": "设置自动同步时间周期，支持5位cron表达式"
        },
        {
          "key": "onlyonce",
          "type": "switch",
          "label": "立即运行一次",
          "default": false,
          "help": "打开后立即运行一次"
        },
        {
          "key": "app_ids",
          "type": "input",
          "label": "企业微信APP ID",
          "default": "",
          "placeholder": "5624501929615254",
          "help": "企业微信APP ID，支持多个id，按逗号分隔"
        },
        {
          "key": "use_cookiecloud",
          "type": "switch",
          "label": "使用CookieCloud",
          "default": false,
          "help": "开启cookiecloud同步，浏览器插件添加同步域名关键词work.weixin.qq.com"
        },
        {
          "key": "use_chrome",
          "type": "switch",
          "label": "使用Chrome仿真",
          "default": false,
          "help": "开启chrome仿真，使用chrome组件模拟登录保活"
        },
        {
          "key": "overwrite",
          "type": "switch",
          "label": "覆盖当前IP列表",
          "default": true,
          "help": "覆盖可信IP列表"
        },
        {
          "key": "cookie",
          "type": "textarea",
          "label": "Cookie",
          "default": "",
          "placeholder": "",
          "help": "企业微信cookie(可选)"
        },
        {
          "key": "notify",
          "type": "switch",
          "label": "运行时通知",
          "default": false,
          "help": "运行任务后发送通知"
        }
      ]
    },
    "slots": []
  }
}
