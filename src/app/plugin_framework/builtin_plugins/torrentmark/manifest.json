{
  "manifest_version": "1.0",
  "id": "torrentmark",
  "name": "种子标记",
  "version": "1.1",
  "author": "linyuan0213",
  "author_url": "https://github.com/linyuan0213",
  "description": "标记种子是否是PT。",
  "category": "tool",
  "tags": ["种子", "标记"],
  "icon": "lucide:tag",
  "color": "#3b82f6",
  "min_app_version": "3.0.0",
  "backend": {
    "entry": "backend.plugin:TorrentMarkPlugin",
    "api_prefix": "/api/plugin/torrentmark",
    "permissions": [],
    "hooks": [
      "plugin.config_changed"
    ],
    "supports_run": true
  },
  "frontend": {
    "routes": [],
    "settings": {
      "component": "SettingsPage",
      "fields": [
        {
          "key": "enable",
          "type": "switch",
          "label": "开启种子标记",
          "default": false,
          "help": "开启后，自动监控下载器，对下载完成的任务根据执行周期标记"
        },
        {
          "key": "cron",
          "type": "cron",
          "label": "执行周期",
          "default": "0 0 * * *",
          "placeholder": "0 0 * * *",
          "help": "标记任务执行的时间周期，支持5位cron表达式"
        },
        {
          "key": "onlyonce",
          "type": "switch",
          "label": "立即运行一次",
          "default": false,
          "help": "打开后立即运行一次"
        }
      ]
    },
    "slots": []
  }
}
